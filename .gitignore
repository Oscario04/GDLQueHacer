.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Entorno virtual ───────────────────────────
venv/
.venv/
env/
.env/

# ── ML / Reportes generados ───────────────────
ml/reports/
*.pkl
*.joblib
*.model

# ── Logs ──────────────────────────────────────
*.log
logs/

# ── IDEs ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ─────────────────────────────────────
.DS_Store
.AppleDouble

# ── Windows ───────────────────────────────────
Thumbs.db
desktop.ini

# ── Testing ───────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Node (por si agregas frontend React) ──────
node_modules/
.next/
out/