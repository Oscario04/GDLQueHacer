# ─────────────────────────────────────────────
# GDL Qué Hacer — Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env al repositorio
# ─────────────────────────────────────────────

# ── MongoDB Atlas ──────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/gdlquehacer?retryWrites=true&w=majority

# ── Eventbrite ─────────────────────────────────
EVENTBRITE_TOKEN=tu_token_de_eventbrite_aqui

# ── JWT (autenticación) ────────────────────────
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── FastAPI ────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── CORS (separa múltiples orígenes con coma) ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Nominatim (geocodificación) ────────────────
NOMINATIM_USER_AGENT=GDLQueHacer/1.0 (contacto@gdlquehacer.mx)